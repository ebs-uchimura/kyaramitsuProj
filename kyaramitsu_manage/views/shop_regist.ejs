<!DOCTYPE html>
<html lang="ja">

  <head>
    <meta charset="UTF-8">
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/manage.css">
    <link rel="stylesheet" href="/css/button.css">
    <script src="https://code.jquery.com/jquery-3.3.1.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/timepicker/1.3.5/jquery.timepicker.min.css">
    <script src="https://postcode-jp.com/js/postcodejp.js" charset="utf-8"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/timepicker/1.3.5/jquery.timepicker.min.js"></script>
    <script src="/js/manage.js"></script>
  </head>

  <body>
    <header>
      <h2><%= title %></h2>
      <a href="/">前の画面へ戻る</a>
    </header>
    <main>
      <div class="shop-row-wrapper">
        <div class="shop-row-parent">
          <form action="/regist" id="shopform" method="post" enctype="multipart/form-data">
            <ul class="shop-row-input-area">
              <h3>&ensp;店舗情報</h3>
              <li class="inputarea shop-row-children">
                <label for="shopname">&ensp;店舗名</label><br>
                <input type="text" id="shopname" class="wide" name="shopname" value="" placeholder="えびす軒">
              </li>
              <li class="inputarea shop-row-children">
                <label for="headline">&ensp;店舗見出し</label><br>
                <input type="text" id="headline" class="superwide" name="headline" value="" placeholder="昭和35年創業の名店">
              </li>
              <li class="inputarea shop-row-children">
                <label for="detail">&ensp;店舗詳細</label><br>
                <textarea id="detail" class="textarea" rows="5" cols="80" name="detail" value=""
                  placeholder="えびす軒は昭和35年創業のラーメン店です。ぜひご来店ください。"></textarea>
              </li>
              <h3>&ensp;営業時間1</h3>
              <li class="inputarea shop-row-children">
                <label for="businesstime1_1">&ensp;営業開始時間1</label><br>
                <input type="text" id="businesstime1_1" class="timepicker1" name="businesstime1_1"
                  autocomplete="off" /><br><br>
                <label for="businesstime1_2">&ensp;営業終了時間1</label><br>
                <input type="text" id="businesstime1_2" class="timepicker2" name="businesstime1_2" autocomplete="off" />
              </li>
              <h3>&ensp;営業時間2</h3>
              <li class="inputarea shop-row-children">
                <label for="businesstime2_1">&ensp;営業開始時間2</label><br>
                <input type="text" id="businesstime2_1" class="timepicker1" name="businesstime2_1"
                  autocomplete="off" /><br><br>
                <label for="businesstime2_2">&ensp;営業終了時間2</label><br>
                <input type="text" id="businesstime2_2" class="timepicker2" name="businesstime2_2" autocomplete="off" />
              </li>
              <h3>&ensp;店舗住所</h3>
              <li class="inputarea shop-row-children">
                〒&ensp;&ensp;&nbsp;<input type="text" id="sample1_zip" name="zip" class="default"><br><br>
                住所&ensp;<input type="text" id="sample1_addr" name="address" class="superwide">
                <div>※必ず都道府県から入力してください。</div>
              </li>
              <h3>&ensp;認定エリア名</h3>
              <li class="inputarea shop-row-children">
                <input type="text" id="" name="cityname" class="default">
                認定エリア名
              </li>
              <h3>&ensp;定休日</h3>
              <li class="inputarea shop-row-children">
                <div>
                  <input type="checkbox" id="sunday" name="holiday" value="0">
                  <label for="sunday">日曜日</label>
                </div>
                <div>
                  <input type="checkbox" id="monday" name="holiday" value="1">
                  <label for="monday">月曜日</label>
                </div>
                <div>
                  <input type="checkbox" id="tuesday" name="holiday" value="2">
                  <label for="tuesday">火曜日</label>
                </div>
                <div>
                  <input type="checkbox" id="wednesday" name="holiday" value="3">
                  <label for="wednesday">水曜日</label>
                </div>
                <div>
                  <input type="checkbox" id="thursday" name="holiday" value="4">
                  <label for="thursday">木曜日</label>
                </div>
                <div>
                  <input type="checkbox" id="friday" name="holiday" value="5">
                  <label for="friday">金曜日</label>
                </div>
                <div>
                  <input type="checkbox" id="saturday" name="holiday" value="6">
                  <label for="saturday">土曜日</label>
                </div>
              </li>
              <h3>&ensp;掲載画像</h3>
              <li class="inputarea shop-row-children">
                <div id="filearea1" class="filearea">
                  <input class="showpath" type="checkbox">&ensp;ファイル選択&ensp;
                  <input type="text" class="superwide" name="filepath1" value="" placeholder="">
                  <input type="file" class="display-none" name="file1">
                </div>
                <div id="filearea2" class="filearea">
                  <input class="showpath" type="checkbox">&ensp;ファイル選択&ensp;
                  <input type="text" class="superwide" name="filepath2" value="" placeholder="">
                  <input type="file" class="display-none" name="file2">
                </div>
                <div id="filearea3" class="filearea">
                  <input class="showpath" type="checkbox">&ensp;ファイル選択&ensp;
                  <input type="text" class="superwide" name="filepath3" value="" placeholder="">
                  <input type="file" class="display-none" name="file3">
                </div>
                <div id="filearea4" class="filearea">
                  <input class="showpath" type="checkbox">&ensp;ファイル選択&ensp;
                  <input type="text" class="superwide" name="filepath4" value="" placeholder="">
                  <input type="file" class="display-none" name="file4">
                </div>
                <div id="filearea5" class="filearea">
                  <input class="showpath" type="checkbox">&ensp;ファイル選択&ensp;
                  <input type="text" class="superwide" name="filepath5" value="" placeholder="">
                  <input type="file" class="display-none" name="file5">
                </div>
              </li>
              <h3>&ensp;備考</h3>
              <li class="inputarea shop-row-children">
                <textarea id="remark" class="textarea" rows="5" cols="80" name="remark" value=""
                  placeholder="その他記載事項（お客様には見えません）"></textarea>
              </li>
            </ul>
            <ul class="shop-row-check-area">
              <li class="shop-button-children">
                <button class="button-g button-7 button-wide" type="submit" value="">店舗登録する</button>
              </li>
            </ul>
          </form>
        </div>
      </div>
    </main>
    <%- include('./partials/manage_footer.ejs') %>
  </body>

</html>